# CloudSync backend environment configuration.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Validated at boot by src/config/env.ts — missing/invalid values crash the process.

# Runtime mode: development | test | production
NODE_ENV=development

# HTTP port the express server listens on
PORT=3000

# PostgreSQL connection string (must include pgvector-enabled database)
DATABASE_URL=postgresql://user:pass@localhost:5432/cloudsync

# Google AI API key — used for all agent Gemini calls.
# Create at: https://console.cloud.google.com/apis/credentials (Generative
# Language API must be enabled, and the key must NOT be restricted to other APIs).
VERTEX_API_KEY=replace-with-vertex-api-key

# Default model for per-resource agent calls (high volume, cost-sensitive).
GEMINI_MODEL_DEFAULT=gemini-2.5-flash

# Model used for destructive-action proposals + MFA-gated remediation.
# More expensive but worth it on the small subset of high-risk decisions.
GEMINI_MODEL_HIGH_STAKES=gemini-2.5-pro

# 32-byte symmetric key for credential vault (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=replace-with-64-hex-chars-representing-32-bytes-00000000000000000

# Secret used to sign session/JWT tokens (min 32 chars)
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# When true, the app serves seeded demo data instead of hitting real cloud providers
DEMO_MODE=false

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": ".",
    "outDir": "./dist",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],

    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "prisma/**/*.ts", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}